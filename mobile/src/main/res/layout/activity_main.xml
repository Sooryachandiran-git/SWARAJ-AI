<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/swaraj_bg_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SWARAJ AI"
            android:textColor="@color/swaraj_white"
            android:textSize="32sp"
            android:fontFamily="sans-serif-black"
            android:gravity="center"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="On-Device Cognitive Intelligence"
            android:textColor="@color/swaraj_text_dim"
            android:textSize="13sp"
            android:gravity="center"
            android:letterSpacing="0.1"
            android:layout_marginBottom="32dp" />

        <!-- Mic / status orb -->
        <FrameLayout
            android:id="@+id/mic_container"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_gravity="center"
            android:background="@drawable/glass_card"
            android:elevation="8dp"
            android:layout_marginBottom="32dp">

            <ImageView
                android:id="@+id/mic_button"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_btn_speak_now"
                android:tint="@color/swaraj_white" />

            <TextView
                android:id="@+id/status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="20dp"
                android:text="TAP TO SPEAK"
                android:textColor="@color/swaraj_saffron"
                android:textSize="11sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- Controls -->
        <TextView
            android:id="@+id/accessibility_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_card"
            android:padding="12dp"
            android:text="⚠️ Accessibility Service Limited"
            android:textColor="@color/swaraj_saffron"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_card"
            android:padding="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Hands-free 'Swaraj' Wake Word"
                android:textColor="@color/swaraj_white"
                android:textSize="14sp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/wake_word_toggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="@color/swaraj_saffron"
                android:trackTint="@color/swaraj_glass_white" />
        </LinearLayout>

        <Button
            android:id="@+id/setup_button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="@color/swaraj_green"
            android:text="CONFIGURE PERMISSIONS"
            android:textColor="@color/swaraj_white"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- Console -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="COGNITIVE CONSOLE"
            android:textColor="@color/swaraj_text_dim"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:background="@drawable/glass_card"
            android:padding="8dp">
            <TextView
                android:id="@+id/cognitive_console"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SYSTEM READY...\n"
                android:textColor="#00FF41"
                android:textSize="11sp"
                android:fontFamily="monospace" />
        </ScrollView>

    </LinearLayout>
</ScrollView>
